# ============== LLM  ==============
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048

# ============== Embedding ==============
EMBED_MODEL=BAAI/bge-small-zh-v1.5
EMBED_DIM=512
EMBED_DEVICE=cpu

# ============== Reranker (可选) ==============
# 启用后召回流程：vec+BM25 → RRF → top_k*pool_factor → CrossEncoder → top_k
# 模型首次调用时下载 (~280MB for bge-reranker-base)；多语言可换 BAAI/bge-reranker-v2-m3
ENABLE_RERANK=false
RERANK_MODEL=BAAI/bge-reranker-base
RERANK_DEVICE=cpu
RERANK_POOL_FACTOR=4
RERANK_MAX_LENGTH=512
RERANK_BATCH_SIZE=16

# ============== Milvus ==============
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=mythicmobs_docs

# ============== Redis ==============
REDIS_URL=redis://redis:6379/0

# ============== App ==============
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
WIKI_ROOT=/wiki
MAX_PROMPT_CHARS=8000
RATE_LIMIT_PER_MINUTE=30
RAG_TOP_K=8
SESSION_TTL_SECONDS=3600
