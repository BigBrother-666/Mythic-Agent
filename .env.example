# ============== LLM  ==============
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048

# ============== Embedding ==============
# Wiki 为英文时推荐英文模型 + 开启 HyDE（中文查询由 HyDE 翻译为英文再检索）
# 英文推荐：BAAI/bge-base-en-v1.5 (768维) 或 BAAI/bge-large-en-v1.5 (1024维)
# 中英混合：BAAI/bge-m3 (1024维)
# 注意：换模型必须同步修改 EMBED_DIM 并 --drop 重建 collection
EMBED_MODEL=BAAI/bge-small-zh-v1.5
EMBED_DIM=512
EMBED_DEVICE=cpu
EMBED_BATCH_SIZE=16

# ============== Reranker (可选) ==============
# 启用后召回流程：vec+BM25 → RRF → top_k*pool_factor → CrossEncoder → top_k
# 模型首次调用时下载 (~280MB for bge-reranker-base)；多语言可换 BAAI/bge-reranker-v2-m3
ENABLE_RERANK=false
RERANK_MODEL=BAAI/bge-reranker-base
RERANK_DEVICE=cpu
RERANK_POOL_FACTOR=4
RERANK_MAX_LENGTH=512
RERANK_BATCH_SIZE=16

# ============== HyDE (可选) ==============
# 启用后向量检索前先用 LLM 生成英文假设性文档，用其 embedding 替代原始 query
# 同时 BM25 会合并原始 query 的英文标识符 + HyDE 英文 token，提升跨语言召回
ENABLE_HYDE=false
HYDE_MODEL=
HYDE_MAX_TOKENS=256

# ============== Milvus ==============
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=mythicmobs_docs

# ============== Redis ==============
REDIS_URL=redis://redis:6379/0

# ============== App ==============
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
WIKI_ROOT=./wiki
MAX_PROMPT_CHARS=8000
RATE_LIMIT_PER_MINUTE=30
RAG_TOP_K=8
SESSION_TTL_SECONDS=3600

# ============== Agent Tool-Calling ==============
# generator 阶段可调用的工具列表（逗号分隔）
AGENT_TOOLS=wiki_search,list_mechanics,list_targeters,list_triggers,list_conditions
# generator 单次生成中最多调用工具的次数
MAX_TOOL_CALLS=8

# ============== Memory 持久化 ==============
# memory_backend = memory / redis
#   memory —— 进程内 LRU+TTL
#   redis  —— 持久化到 Redis
MEMORY_BACKEND=redis
MEMORY_REDIS_PREFIX=mma:sess:

# ============== LangFuse (可选) ==============
# 启用后自动追踪 agent 全链路（LLM 调用、检索、HyDE 等），通过 Web UI 查看
# 启动 LangFuse：docker compose --profile langfuse up -d
# 首次访问 http://localhost:3000 注册账号后获取 public/secret key
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000
