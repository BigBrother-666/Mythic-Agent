# ============== LLM  ==============
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048

# ============== Embedding ==============
EMBED_MODEL=BAAI/bge-small-zh-v1.5
EMBED_DIM=512
EMBED_DEVICE=cpu

# ============== Milvus ==============
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=mythicmobs_docs

# ============== Redis ==============
REDIS_URL=redis://redis:6379/0

# ============== App ==============
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
WIKI_ROOT=/wiki
MAX_PROMPT_CHARS=8000
RATE_LIMIT_PER_MINUTE=30
ENABLE_RERANK=false
RAG_TOP_K=8
SESSION_TTL_SECONDS=3600
